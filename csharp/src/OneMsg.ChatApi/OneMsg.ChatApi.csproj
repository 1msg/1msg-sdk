<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo><!-- setting GenerateAssemblyInfo to false causes this bug https://github.com/dotnet/project-system/issues/3934 -->
    <TargetFramework>netstandard2.0</TargetFramework>
    <AssemblyName>OneMsg.ChatApi</AssemblyName>
    <PackageId>OneMsg.ChatApi</PackageId>
    <OutputType>Library</OutputType>
    <Authors>1MSG</Authors>
    <Company>1MSG</Company>
    <AssemblyTitle>1MSG Chat API SDK</AssemblyTitle>
    <Description>Public 1MSG Chat API client SDK</Description>
    <Copyright>Copyright 1MSG</Copyright>
    <RootNamespace>OneMsg.ChatApi</RootNamespace>
    <Version>1.0.2</Version>
    <DocumentationFile>bin\$(Configuration)\$(TargetFramework)\OneMsg.ChatApi.xml</DocumentationFile>
    <RepositoryUrl>https://github.com/1msg/1msg-sdk</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageReleaseNotes>Generated from the public 1MSG Chat API OpenAPI spec.</PackageReleaseNotes>
    <PackageTags>1msg-chat-api-whatsapp</PackageTags>
    <ManagePackageVersionsCentrally>false</ManagePackageVersionsCentrally>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/1msg/1msg-sdk</PackageProjectUrl>
      <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="JsonSubTypes" Version="2.0.1" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    <PackageReference Include="Polly" Version="8.1.0" />
    <PackageReference Include="System.ComponentModel.Annotations" Version="5.0.0" />
  </ItemGroup>

  <ItemGroup>
    <None Remove="System.Web" />
  </ItemGroup>
  <ItemGroup>
    <Reference Include="System.Web" />
  </ItemGroup>
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>
